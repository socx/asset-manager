// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // Explicit output ensures the generated client lands in the monorepo root
  // node_modules so all workspaces can import it without hoisting issues.
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum Role {
  super_admin
  system_admin
  asset_manager
  asset_owner
}

enum UserStatus {
  pending_verification
  active
  disabled
}

enum LogLevel {
  debug
  info
  warn
  error
  fatal
}

enum LookupItemType {
  document_type
  asset_class
  transaction_category
  company_type
  property_status
  property_purpose
  ownership_type
  mortgage_type
  mortgage_payment_status
}

// ── Models ─────────────────────────────────────────────────────────────────────

/// NOTE: Primary keys use gen_random_uuid() (UUID v4) for now.
/// UUID v7 requires a custom PostgreSQL function — planned for a follow-up migration.
model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String     @unique
  passwordHash        String     @map("password_hash")
  firstName           String     @map("first_name")
  lastName            String     @map("last_name")
  role                Role       @default(asset_owner)
  status              UserStatus @default(pending_verification)
  emailVerifiedAt     DateTime?  @map("email_verified_at")
  mfaEnabled          Boolean    @default(false) @map("mfa_enabled")
  mfaSecret           String?    @map("mfa_secret")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  lastLoginAt         DateTime?  @map("last_login_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  sessions            UserSession[]
  emailVerifications  EmailVerification[]
  passwordResetTokens PasswordResetToken[]
  mfaBackupCodes      MfaBackupCode[]
  auditLogs           AuditLog[]
  ownedProperties     PropertyAsset[]      @relation("PropertyOwner")
  managedProperties   PropertyAsset[]      @relation("PropertyManagerUser")

  @@map("users")
}

model UserSession {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  refreshTokenHash  String    @map("refresh_token_hash")
  deviceFingerprint String?   @map("device_fingerprint")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model EmailVerification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model MfaBackupCode {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_backup_codes")
}

/// Append-only audit log. Partitioned by month via raw SQL migration (planned iteration 1).
/// DB trigger prevents UPDATE and DELETE on this table.
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  actorId    String?  @map("actor_id") @db.Uuid
  actorRole  String?  @map("actor_role")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// System log for warn/error/fatal level events. Partitioned by month via raw SQL migration.
model SystemLog {
  id        BigInt   @id @default(autoincrement())
  level     LogLevel
  service   String
  message   String
  context   Json?
  traceId   String?  @map("trace_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([createdAt])
  @@index([traceId])
  @@map("system_logs")
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// Single polymorphic table for all admin-managed lookup / reference lists.
model LookupItem {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        LookupItemType
  name        String
  description String?
  sortOrder   Int            @map("sort_order")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  companies                    Company[]
  assetClassProperties         PropertyAsset[]    @relation("PropertyAssetClass")
  ownershipTypeProperties      PropertyAsset[]    @relation("PropertyAssetOwnershipType")
  propertyStatusProperties     PropertyAsset[]    @relation("PropertyAssetStatus")
  propertyPurposeProperties    PropertyAsset[]    @relation("PropertyAssetPurpose")
  mortgageTypeEntries          MortgageEntry[]    @relation("MortgageType")
  mortgagePaymentStatusEntries MortgageEntry[]    @relation("MortgagePaymentStatus")
  transactionCategoryEntries   TransactionEntry[] @relation("TransactionCategory")

  @@unique([type, name])
  @@index([type, isActive, sortOrder])
  @@map("lookup_items")
}

model Company {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @unique
  companyTypeId String?   @map("company_type_id") @db.Uuid
  addressLine1  String?   @map("address_line1")
  addressLine2  String?   @map("address_line2")
  city          String?
  county        String?
  postCode      String?   @map("post_code")
  country       String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  companyType       LookupItem?     @relation(fields: [companyTypeId], references: [id], onDelete: SetNull)
  managedProperties PropertyAsset[] @relation("PropertyManagerCompany")

  @@index([isActive])
  @@map("companies")
}

model PropertyAsset {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String    @unique
  customAlias        String?   @unique @map("custom_alias")
  assetClassId       String    @map("asset_class_id") @db.Uuid
  ownerId            String    @map("owner_id") @db.Uuid
  managedByUserId    String?   @map("managed_by_user_id") @db.Uuid
  managedByCompanyId String?   @map("managed_by_company_id") @db.Uuid
  ownershipTypeId    String    @map("ownership_type_id") @db.Uuid
  addressLine1       String    @map("address_line1")
  addressLine2       String?   @map("address_line2")
  city               String
  county             String?
  postCode           String    @map("post_code")
  country            String
  propertyStatusId   String    @map("property_status_id") @db.Uuid
  propertyPurposeId  String    @map("property_purpose_id") @db.Uuid
  description        String?
  purchaseDate       DateTime? @map("purchase_date")
  purchasePrice      Decimal?  @map("purchase_price") @db.Decimal(14, 2)
  isFinanced         Boolean?  @map("is_financed")
  depositPaid        Decimal?  @map("deposit_paid") @db.Decimal(14, 2)
  dutiesTaxes        Decimal?  @map("duties_taxes") @db.Decimal(14, 2)
  legalFees          Decimal?  @map("legal_fees") @db.Decimal(14, 2)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  assetClass       LookupItem          @relation("PropertyAssetClass", fields: [assetClassId], references: [id], onDelete: Restrict)
  owner            User                @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  managedByUser    User?               @relation("PropertyManagerUser", fields: [managedByUserId], references: [id], onDelete: SetNull)
  managedByCompany Company?            @relation("PropertyManagerCompany", fields: [managedByCompanyId], references: [id], onDelete: SetNull)
  ownershipType    LookupItem          @relation("PropertyAssetOwnershipType", fields: [ownershipTypeId], references: [id], onDelete: Restrict)
  propertyStatus   LookupItem          @relation("PropertyAssetStatus", fields: [propertyStatusId], references: [id], onDelete: Restrict)
  propertyPurpose  LookupItem          @relation("PropertyAssetPurpose", fields: [propertyPurposeId], references: [id], onDelete: Restrict)
  valuations       ValuationEntry[]
  mortgages        MortgageEntry[]
  shareholdings    ShareholdingEntry[]
  transactions     TransactionEntry[]

  @@index([ownerId])
  @@index([managedByUserId])
  @@index([deletedAt])
  @@index([postCode])
  @@map("property_assets")
}

model ValuationEntry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId         String   @map("asset_id") @db.Uuid
  valuationDate   DateTime @map("valuation_date")
  valuationAmount Decimal  @map("valuation_amount") @db.Decimal(14, 2)
  valuationMethod String   @map("valuation_method")
  valuedBy        String?  @map("valued_by")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  asset PropertyAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, valuationDate])
  @@map("valuation_entries")
}

model MortgageEntry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId         String    @map("asset_id") @db.Uuid
  lender          String
  productName     String?   @map("product_name")
  mortgageTypeId  String    @map("mortgage_type_id") @db.Uuid
  loanAmount      Decimal   @map("loan_amount") @db.Decimal(14, 2)
  interestRate    Decimal?  @map("interest_rate") @db.Decimal(7, 4)
  termYears       Int?      @map("term_years")
  paymentStatusId String    @map("payment_status_id") @db.Uuid
  startDate       DateTime  @map("start_date")
  settledAt       DateTime? @map("settled_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  asset         PropertyAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  mortgageType  LookupItem    @relation("MortgageType", fields: [mortgageTypeId], references: [id], onDelete: Restrict)
  paymentStatus LookupItem    @relation("MortgagePaymentStatus", fields: [paymentStatusId], references: [id], onDelete: Restrict)

  @@index([assetId, settledAt])
  @@map("mortgage_entries")
}

model ShareholdingEntry {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId          String   @map("asset_id") @db.Uuid
  shareholderName  String   @map("shareholder_name")
  ownershipPercent Decimal  @map("ownership_percent") @db.Decimal(5, 2)
  profitPercent    Decimal  @map("profit_percent") @db.Decimal(5, 2)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  asset PropertyAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("shareholding_entries")
}

model TransactionEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId     String   @map("asset_id") @db.Uuid
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(14, 2)
  categoryId  String   @map("category_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  asset    PropertyAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  category LookupItem    @relation("TransactionCategory", fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([assetId, date])
  @@map("transaction_entries")
}
