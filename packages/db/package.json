{
  "name": "@asset-manager/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/client.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
